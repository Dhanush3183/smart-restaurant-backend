spring:
  datasource:
    url: jdbc:mysql://localhost:3306/smart_restaurant_db
    username: YOUR_DB_USERNAME
    password: YOUR_DB_PASSWORD
    driver-class-name: com.mysql.cj.jdbc.Driver

  jpa:
    hibernate:
      ddl-auto: update
    properties:
      hibernate:
        dialect: org.hibernate.dialect.MySQLDialect
    show-sql: true

  mail:
    host: smtp.gmail.com
    port: 587
    username: YOUR_EMAIL@gmail.com
    password: YOUR_APP_PASSWORD
    properties:
      mail:
        smtp:
          auth: true
          starttls:
            enable: true
            required: true
      transport:
        protocol: smtp

  mvc:
    pathmatch:
      matching-strategy: ant_path_matcher

  ai:
    ollama:
      base-url: http://localhost:11434
      chat:
        options:
          model: llama3.2:1b
          temperature: 0.3
          top-p: 0.9

server:
  port: 9095

jwt:
  secret: YOUR_JWT_SECRET_KEY_MIN_32_CHARS
  expiration: 86400000

huggingface:
  api-key: YOUR_HF_API_KEY
  endpoint-url: https://api-inference.huggingface.co/models/tiiuae/falcon-7b-instruct
